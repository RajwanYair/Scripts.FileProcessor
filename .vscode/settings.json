{
  // ─── Python interpreter ────────────────────────────────────────────────
  // Note: python.defaultInterpreterPath is intentionally omitted — set this
  // in your personal User Settings to avoid committing machine-specific paths.
  "python.terminal.activateEnvironment": false,
  // ─── Editor defaults ──────────────────────────────────────────────────
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit",
    "source.fixAll.ruff": "explicit"
  },
  "editor.rulers": [
    100
  ],
  "editor.insertSpaces": true,
  "editor.tabSize": 4,
  "files.eol": "\n",
  "files.encoding": "utf8",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  // ─── Ruff (linter + formatter) ────────────────────────────────────────
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true
  },
  "ruff.lint.enable": true,
  "ruff.format.enable": true,
  "ruff.organizeImports": true,
  // ─── Pylance / type checking ──────────────────────────────────────────
  "python.analysis.typeCheckingMode": "standard",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.indexing": true,
  "python.analysis.extraPaths": [
    "src"
  ],
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.stubPath": "typestubs",
  // ─── Testing ─────────────────────────────────────────────────────────
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": [
    "tests",
    "--tb=short",
    "-v"
  ],
  // ─── File exclusions (keep explorer clean) ───────────────────────────
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/*.pyc": true,
    "**/htmlcov": true,
    "**/.hypothesis": true
  },
  "search.exclude": {
    "**/__pycache__": true,
    "**/node_modules": true,
    "**/htmlcov": true,
    "**/.mypy_cache": true,
    "**/.pytest_cache": true
  },
  // ─── Markdown ────────────────────────────────────────────────────────
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
    "editor.wordWrap": "on"
  },
  // ─── YAML ─────────────────────────────────────────────────────────────
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "yaml.schemas": {
    "https://json.schemastore.org/github-workflow.json": ".github/workflows/*.yml"
  }
}
